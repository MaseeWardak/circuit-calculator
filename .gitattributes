# Normalize line endings
* text=auto eol=lf

# C++ sources for diffs
*.c     text diff=cpp
*.cc    text diff=cpp
*.cpp   text diff=cpp
*.cxx   text diff=cpp
*.h     text diff=cpp
*.hpp   text diff=cpp

# GitHub Linguist: treat docs separately (does not count toward "main" language bar)
*.md    linguist-documentation
LICENSE linguist-documentation
